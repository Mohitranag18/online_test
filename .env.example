# Email Configuration
# SMTP server hostname
EMAIL_HOST=smtp.gmail.com

# SMTP server port
EMAIL_PORT=587

# Use TLS for secure connection
EMAIL_USE_TLS=True

# Email address for SMTP authentication
EMAIL_HOST_USER=your_email@gmail.com

# Email password or app-specific password for SMTP authentication
EMAIL_HOST_PASSWORD=your_app_password

# Default "from" email address (can include display name)
DEFAULT_FROM_EMAIL=Your App Name <your_email@gmail.com>

# Social Auth - Google OAuth2
# Get these from https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://127.0.0.1:8000/complete/google-oauth2/
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Social Auth - Facebook OAuth2
# Get these from https://developers.facebook.com/apps/
# Set Valid OAuth Redirect URI to: http://127.0.0.1:8000/complete/facebook/
SOCIAL_AUTH_FACEBOOK_KEY=your-facebook-app-id
SOCIAL_AUTH_FACEBOOK_SECRET=your-facebook-app-secret

# Social Auth - GitHub OAuth
# Get these from https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# Set Authorization callback URL to: http://127.0.0.1:8000/complete/github/
SOCIAL_AUTH_GITHUB_KEY=your-github-client-id
SOCIAL_AUTH_GITHUB_SECRET=your-github-client-secret
